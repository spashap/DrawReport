# DrawReport secrets — copy to .env and fill in. NEVER commit .env.
# The app runs with all of these empty (stubs/placeholders); fill them to go live.

# --- Gemini (report generation) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
# Optional Gemini proxy base url (leave empty to call Google directly)
GOOGLE_GEMINI_BASE_URL=

# --- Admin panel (/admin). Empty = admin disabled (404). ---
ADMIN_PASS=
ADMIN_ALERT_EMAIL=spashap@gmail.com

# --- Google Analytics 4. Empty = no GA snippet. e.g. G-XXXXXXXXXX ---
GA_MEASUREMENT_ID=

# --- Payment: 'stub' until PayPal creds are provided, then 'paypal' ---
PAYMENT_BACKEND=stub
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# --- Email: 'outbox' (writes HTML files in data/outbox) until Resend is set ---
MAIL_BACKEND=outbox
RESEND_API_KEY=
MAIL_FROM_EMAIL=hello@drawreport.com
MAIL_FROM_NAME=DrawReport

# --- i18n (comma-separated active locales) ---
LOCALES=en
DEFAULT_LOCALE=en

# --- Site ---
SITE_DOMAIN=drawreport.com
PUBLIC_BASE_URL=http://localhost:5000
