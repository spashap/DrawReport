projectSpec/testDrawings/
projectSpec/reportSamples/
data/Images/

# environment
venv/
__pycache__/
*.pyc

# local Claude Code settings
.claude/

# compiled translations are generated; keep .po, ignore .mo
translations/**/*.mo
